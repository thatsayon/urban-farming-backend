{
  "compilerOptions": {

    "outDir": "./dist",

    "module": "CommonJS",
    "moduleResolution": "Node",

    "ignoreDeprecations": "6.0",
    "target": "ES2022",

    "lib": ["ES2022"],
    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "verbatimModuleSyntax": false,

    "isolatedModules": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src/**/*", "prisma.config.ts"],
  "ts-node": {
    "files": true
  }
}